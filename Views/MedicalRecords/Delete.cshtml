@model ClinicManagementSystem.Models.MedicalRecord

<h2>Delete Medical Record</h2>

<h4>
    Are you sure you want to delete this?
</h4>

<hr />

<dl class="row">

    <dt class="col-sm-3">
        Patient
    </dt>

    <dd class="col-sm-9">
        @Model.Patient!.FullName
    </dd>

    <dt class="col-sm-3">
        Diagnosis
    </dt>

    <dd class="col-sm-9">
        @Model.Diagnosis
    </dd>

</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">

        Delete

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancel

    </a>

</form>