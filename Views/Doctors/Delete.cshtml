@model ClinicManagementSystem.Models.Doctor

<h2>Delete Doctor</h2>

<h4>Are you sure?</h4>

<div class="mb-3">
    <strong>@Model.FullName</strong>
</div>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
       Cancel
    </a>

</form>