@model IEnumerable<ClinicManagementSystem.Models.Doctor>

<h2 class="mb-4 text-success fw-bold">
    Doctors
</h2>

<a asp-action="Create"
   class="btn btn-success mb-3 shadow-sm">
    Add Doctor
</a>

<div class="card shadow-lg border-0 rounded-4">

    <div class="card-body">

        <table class="table table-hover align-middle">

            <thead class="table-success">

                <tr>
                    <th>Name</th>
                    <th>Specialty</th>
                    <th>Contact</th>
                    <th>Actions</th>
                </tr>

            </thead>

            <tbody>

@foreach (var item in Model)
{
    <tr>

        <td class="fw-semibold">
            @item.FullName
        </td>

        <td>
            @item.Specialty
        </td>

        <td>
            @item.ContactNumber
        </td>

        <td>

            <a asp-action="Edit"
               asp-route-id="@item.Id"
               class="btn btn-warning btn-sm me-2">

                Edit

            </a>

            <a asp-action="Delete"
               asp-route-id="@item.Id"
               class="btn btn-danger btn-sm">

                Delete

            </a>

        </td>

    </tr>
}

            </tbody>

        </table>

    </div>

</div>