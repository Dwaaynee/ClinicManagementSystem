@model ClinicManagementSystem.Models.Patient

<h2>Delete Patient</h2>

<h4>
    Are you sure you want to delete this?
</h4>

<div>

    <strong>
        @Model.FullName
    </strong>

</div>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">

        Delete

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancel

    </a>

</form>