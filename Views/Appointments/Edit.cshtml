@model ClinicManagementSystem.Models.Appointment

<h2>Edit Appointment</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">

        <label class="form-label">
            Patient
        </label>

        <select asp-for="PatientId"
                asp-items="ViewBag.Patients"
                class="form-control">
        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Doctor
        </label>

        <select asp-for="DoctorId"
                asp-items="ViewBag.Doctors"
                class="form-control">
        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Appointment Date
        </label>

        <input asp-for="AppointmentDate"
               type="date"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Appointment Time
        </label>

        <input asp-for="AppointmentTime"
               type="time"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Special Note
        </label>

        <textarea asp-for="SpecialNote"
                  class="form-control">
        </textarea>

    </div>

    <button type="submit"
            class="btn btn-primary">

        Update

    </button>

</form>