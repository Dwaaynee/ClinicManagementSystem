@model ClinicManagementSystem.Models.Appointment

<h2>Delete Appointment</h2>

<h4>
    Are you sure you want to delete this appointment?
</h4>

<hr />

<dl class="row">

    <dt class="col-sm-3">
        Patient
    </dt>

    <dd class="col-sm-9">
        @Model.Patient!.FullName
    </dd>

    <dt class="col-sm-3">
        Doctor
    </dt>

    <dd class="col-sm-9">
        @Model.Doctor!.FullName
    </dd>

    <dt class="col-sm-3">
        Date
    </dt>

    <dd class="col-sm-9">
        @Model.AppointmentDate.ToString("MMMM dd, yyyy")
    </dd>

    <dt class="col-sm-3">
        Time
    </dt>

    <dd class="col-sm-9">
        @Model.AppointmentTime
    </dd>

</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">

        Delete

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancel

    </a>

</form>